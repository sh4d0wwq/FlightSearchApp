<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FlightSearchApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#BB86FC</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">#03DAC6</item>
        <item name="colorSecondaryVariant">#018786</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/dark_background</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnBackground">@color/dark_text_primary</item>
        <item name="colorOnSurface">@color/dark_text_primary</item>
        <item name="cardViewStyle">@style/CardView.Dark</item>
        <item name="colorError">#CF6679</item>
        <item name="colorOnError">@color/black</item>
        <item name="android:statusBarColor">@color/dark_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/dark_background</item>
        <item name="android:textColorPrimary">@color/dark_text_primary</item>
        <item name="android:textColorSecondary">@color/dark_text_secondary</item>
        <item name="android:textColorHint">@color/dark_text_hint</item>
        <item name="materialButtonStyle">@style/Widget.MaterialComponents.Button</item>
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>
        <item name="cardBackground">@color/dark_card</item>
        <item name="textPrimary">@color/dark_text_primary</item>
        <item name="textSecondary">@color/dark_text_secondary</item>
    </style>

    <style name="CardView.Dark" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/dark_card</item>
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">12dp</item>
    </style>

    <style name="Widget.MaterialComponents.TextInputLayout.OutlinedBox" parent="">
        <item name="boxStrokeColor">@color/primary_color</item>
        <item name="hintTextColor">@color/dark_text_secondary</item>
        <item name="android:textColorHint">@color/dark_text_hint</item>
    </style>

    <style name="Theme.App.Splash" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@color/dark_background</item>
        <item name="android:statusBarColor">@color/dark_background</item>
        <item name="android:navigationBarColor">@color/dark_background</item>
    </style>
</resources>