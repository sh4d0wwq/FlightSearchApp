<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FlightSearchApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorPrimaryVariant">@color/primary_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_color</item>
        <item name="colorSecondaryVariant">@color/primary_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/light_background</item>
        <item name="colorSurface">@color/light_surface</item>
        <item name="colorOnBackground">@color/light_text_primary</item>
        <item name="colorOnSurface">@color/light_text_primary</item>
        <item name="cardViewStyle">@style/CardView.Light</item>
        <item name="colorError">@color/error_color</item>
        <item name="colorOnError">@color/white</item>
        <item name="android:statusBarColor">@color/primary_color</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/primary_color</item>
        <item name="android:textColorPrimary">@color/light_text_primary</item>
        <item name="android:textColorSecondary">@color/light_text_secondary</item>
        <item name="android:textColorHint">@color/light_text_hint</item>
        <item name="materialButtonStyle">@style/Widget.MaterialComponents.Button</item>
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>
        <item name="cardBackground">@color/light_card</item>
        <item name="textPrimary">@color/light_text_primary</item>
        <item name="textSecondary">@color/light_text_secondary</item>
    </style>

    <style name="CardView.Light" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/light_card</item>
        <item name="cardElevation">4dp</item>
    </style>

    <style name="Theme.App.Splash" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@color/primary_color</item>
        <item name="android:statusBarColor">@color/primary_color</item>
        <item name="android:navigationBarColor">@color/primary_color</item>
    </style>

    <declare-styleable name="Theme">
        <attr name="cardBackground" format="color" />
        <attr name="textPrimary" format="color" />
        <attr name="textSecondary" format="color" />
    </declare-styleable>
</resources>